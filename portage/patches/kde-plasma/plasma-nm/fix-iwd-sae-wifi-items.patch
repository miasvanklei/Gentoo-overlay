From d8ef9acd96c518e9090a21319b78c45f15e17116 Mon Sep 17 00:00:00 2001
From: Aleks Man <aleksman4o@gmail.com>
Date: Wed, 20 May 2026 02:29:40 +0300
Subject: [PATCH 1/2] libs/models: rebind active wifi items to device and AP

When a Wi-Fi profile becomes active while it is not currently exposed as an available connection on the device, the model still receives an ActiveConnection. The existing code only updated the active state and left the item detached from the device, which kept it in the unavailable branch of the model and made the applet hide it.

Synchronize the item with the active device, refresh its AP-backed details, and drop the duplicate access-point-only entry once the saved connection becomes active.

BUG: 441711
---
 libs/models/networkmodel.cpp | 53 ++++++++++++++++++++++++++++++++++++
 1 file changed, 53 insertions(+)

diff --git a/libs/models/networkmodel.cpp b/libs/models/networkmodel.cpp
index 96dcad93d..ac7e6a460 100644
--- a/libs/models/networkmodel.cpp
+++ b/libs/models/networkmodel.cpp
@@ -18,6 +18,25 @@
 #include <NetworkManagerQt/Settings>
 #include <NetworkManagerQt/Manager>
 
+namespace
+{
+void syncItemWithDevice(NetworkModelItem *item, const NetworkManager::Device::Ptr &device)
+{
+    if (!item || !device) {
+        return;
+    }
+
+    if (device->ipInterfaceName().isEmpty()) {
+        item->setDeviceName(device->interfaceName());
+    } else {
+        item->setDeviceName(device->ipInterfaceName());
+    }
+
+    item->setDevicePath(device->uni());
+    item->setDeviceState(device->state());
+}
+}
+
 NetworkModel::NetworkModel(QObject *parent)
     : QAbstractListModel(parent)
 {
@@ -350,6 +369,10 @@ void NetworkModel::addActiveConnection(const NetworkManager::ActiveConnection::P
 
     for (const auto items = m_list.returnItems(NetworkItemsList::NetworkItemsList::Uuid, connection->uuid()); NetworkModelItem * item : items) {
         if (((device && device->uni() == item->devicePath()) || item->devicePath().isEmpty()) || item->type() == NetworkManager::ConnectionSettings::Vpn) {
+            if (device) {
+                syncItemWithDevice(item, device);
+            }
+
             item->setActiveConnectionPath(activeConnection->path());
             item->setConnectionState(activeConnection->state());
             if (activeConnection->vpn()) {
@@ -367,6 +390,36 @@ void NetworkModel::addActiveConnection(const NetworkManager::ActiveConnection::P
                 }
                 item->setVpnState(state);
             }
+
+            if (item->type() == NetworkManager::ConnectionSettings::Wireless && device && device->type() == NetworkManager::Device::Wifi) {
+                NetworkManager::WirelessDevice::Ptr wifiDevice = device.objectCast<NetworkManager::WirelessDevice>();
+                if (wifiDevice) {
+                    if (!activeConnection->specificObject().isEmpty()) {
+                        item->setSpecificPath(activeConnection->specificObject());
+                    }
+
+                    NetworkManager::WirelessNetwork::Ptr network;
+                    NetworkManager::AccessPoint::Ptr ap = wifiDevice->findAccessPoint(activeConnection->specificObject());
+                    if (ap) {
+                        network = wifiDevice->findNetwork(ap->ssid());
+                    }
+                    if (!network) {
+                        network = wifiDevice->findNetwork(item->ssid());
+                    }
+                    if (network) {
+                        updateFromWirelessNetwork(item, network, wifiDevice);
+                    }
+
+                    for (NetworkModelItem *secondItem : m_list.returnItems(NetworkItemsList::Ssid, item->ssid(), device->uni())) {
+                        if (secondItem != item && secondItem->itemType() == NetworkModelItem::AvailableAccessPoint) {
+                            removeItem(secondItem);
+                            qCDebug(PLASMA_NM_LIBS_LOG).nospace()
+                                << "Access point " << secondItem->name() << ": merged to active " << item->name() << " connection";
+                        }
+                    }
+                }
+            }
+
             qCDebug(PLASMA_NM_LIBS_LOG).nospace() << "Item " << item->name() << ": active connection state changed to " << item->connectionState();
 
