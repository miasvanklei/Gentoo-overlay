From dcd9e2af19a71f83989edf65e96f6fdb01badf6f Mon Sep 17 00:00:00 2001
From: Aleks Man <aleksman4o@gmail.com>
Date: Wed, 20 May 2026 02:29:45 +0300
Subject: [PATCH 2/2] libs/models: merge hidden SAE profiles with scanned APs

With iwd and an SAE profile on a WPA2/WPA3 transition network,
NetworkManager may keep the profile saved but stop listing it in
device->availableConnections(). The applet then keeps only the
scan-derived access-point item, treats it as a raw AP entry, and routes
clicks through addAndActivateConnection() instead of activating the
saved profile.

Allow AP scans to merge back into an unavailable saved SAE profile with
matching SSID/BSSID constraints, even if that profile is currently in
the unavailable branch. When refreshing a merged item, prefer the
security type from the saved connection settings only for SAE profiles,
so the saved profile is not visually downgraded to the transition-mode
AP security label.

BUG: 441711
---
 libs/models/networkmodel.cpp | 66 +++++++++++++++++++++++++++++-------
 1 file changed, 54 insertions(+), 12 deletions(-)

diff --git a/libs/models/networkmodel.cpp b/libs/models/networkmodel.cpp
index ac7e6a460..4fb8603cd 100644
--- a/libs/models/networkmodel.cpp
+++ b/libs/models/networkmodel.cpp
@@ -584,26 +584,63 @@ void NetworkModel::addWirelessNetwork(const NetworkManager::WirelessNetwork::Ptr
     // attempt to merge with an AP, based on its SSID, but it doesn't find any, because we have AP with empty SSID. After this we get another
     // AccessPoint appeared signal, this time we know SSID, but we don't attempt any merging, because it's usually the other way around, thus
     // we need to attempt to merge it here with a connection we guess it's related to this new AP
+    NetworkModelItem *hiddenSaeItem = nullptr;
+    bool hiddenSaeItemAmbiguous = false;
     for (NetworkModelItem *item : m_list.returnItems(NetworkItemsList::Type, NetworkManager::ConnectionSettings::Wireless)) {
-        if (item->itemType() != NetworkModelItem::AvailableConnection)
+        if (item->connectionPath().isEmpty()) {
             continue;
+        }
+
+        NetworkManager::Connection::Ptr connection = NetworkManager::findConnection(item->connectionPath());
+        if (!connection) {
+            continue;
+        }
 
-        NetworkManager::ConnectionSettings::Ptr connectionSettings = NetworkManager::findConnection(item->connectionPath())->settings();
-        if (connectionSettings && connectionSettings->connectionType() == NetworkManager::ConnectionSettings::Wireless) {
-            NetworkManager::WirelessSetting::Ptr wirelessSetting =
-                connectionSettings->setting(NetworkManager::Setting::Wireless).dynamicCast<NetworkManager::WirelessSetting>();
-            if (QString::fromUtf8(wirelessSetting->ssid()) == network->ssid()) {
-                const QString bssid = NetworkManager::macAddressAsString(wirelessSetting->bssid());
-                const QString restrictedHw = NetworkManager::macAddressAsString(wirelessSetting->macAddress());
-                if ((bssid.isEmpty() || bssid == network->referenceAccessPoint()->hardwareAddress())
-                    && (restrictedHw.isEmpty() || restrictedHw == device->hardwareAddress())) {
-                    updateFromWirelessNetwork(item, network, device);
-                    return;
+        NetworkManager::ConnectionSettings::Ptr connectionSettings = connection->settings();
+        if (!connectionSettings || connectionSettings->connectionType() != NetworkManager::ConnectionSettings::Wireless) {
+            continue;
+        }
+
+        NetworkManager::WirelessSetting::Ptr wirelessSetting =
+            connectionSettings->setting(NetworkManager::Setting::Wireless).dynamicCast<NetworkManager::WirelessSetting>();
+        if (!wirelessSetting || QString::fromUtf8(wirelessSetting->ssid()) != network->ssid()) {
+            continue;
+        }
+
+        const QString bssid = NetworkManager::macAddressAsString(wirelessSetting->bssid());
+        const QString restrictedHw = NetworkManager::macAddressAsString(wirelessSetting->macAddress());
+        if ((bssid.isEmpty() || bssid == network->referenceAccessPoint()->hardwareAddress())
+            && (restrictedHw.isEmpty() || restrictedHw == device->hardwareAddress())) {
+            if (item->itemType() == NetworkModelItem::AvailableConnection) {
+                updateFromWirelessNetwork(item, network, device);
+                return;
+            }
+
+            const NetworkManager::WirelessSecurityType connectionSecurity =
+                NetworkManager::securityTypeFromConnectionSetting(connectionSettings);
+            if (item->itemType() == NetworkModelItem::UnavailableConnection && connectionSecurity == NetworkManager::SAE) {
+                if (hiddenSaeItem) {
+                    hiddenSaeItemAmbiguous = true;
+                } else {
+                    hiddenSaeItem = item;
                 }
             }
         }
     }
 
+    if (hiddenSaeItem && !hiddenSaeItemAmbiguous) {
+        syncItemWithDevice(hiddenSaeItem, device);
+        updateFromWirelessNetwork(hiddenSaeItem, network, device);
+        for (NetworkModelItem *secondItem : m_list.returnItems(NetworkItemsList::Ssid, hiddenSaeItem->ssid(), device->uni())) {
+            if (secondItem != hiddenSaeItem && secondItem->itemType() == NetworkModelItem::AvailableAccessPoint) {
+                removeItem(secondItem);
+                qCDebug(PLASMA_NM_LIBS_LOG).nospace()
+                    << "Access point " << secondItem->name() << ": merged to " << hiddenSaeItem->name() << " connection";
+            }
+        }
+        return;
+    }
+
     NetworkManager::WirelessSetting::NetworkMode mode = NetworkManager::WirelessSetting::Infrastructure;
     NetworkManager::WirelessSecurityType securityType = NetworkManager::UnknownSecurity;
 
@@ -1262,6 +1299,11 @@ void NetworkModel::updateFromWirelessNetwork(NetworkModelItem *item,
     // Check whether the connection is associated with some concrete AP
     NetworkManager::Connection::Ptr connection = NetworkManager::findConnection(item->connectionPath());
     if (connection) {
